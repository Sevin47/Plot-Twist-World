# Optional — enables shared-world multiplayer. Without these, the game
# runs single-player using localStorage.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional — enables real geography for district classification (actual
# OSM water/land-use/building data instead of an approximate procedural
# guess). Without this, the game falls back to a coarser built-in model.
VITE_PROTOMAPS_KEY=YOUR-PROTOMAPS-API-KEY
